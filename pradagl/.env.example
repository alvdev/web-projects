# =============================================================
# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# =============================================================
# Site key is exposed to the browser (use the PUBLIC_ prefix).
PUBLIC_TURNSTILE_SITEKEY=public-key-should-be-exposed-to-client
# Secret key MUST stay on the server — never expose it to the client.
TURNSTILE_SECRET=secret-key-should-be-kept-private

# =============================================================
# SMTP relay (e.g. Mailtrap, SendGrid, Gmail, your own Postfix)
# =============================================================
# Use port 465 with SMTP_SECURE=true, OR port 587 with SMTP_SECURE=false (STARTTLS).
SMTP_HOST=smtp.domain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@domain.com
SMTP_PASS=super-secret-password

# Email metadata
SMTP_FROM="Company <user@domain.com>"
SMTP_TO=user@domain.com
