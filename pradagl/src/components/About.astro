---
const bullets = [
  {
    title: "Trazabilidad en tiempo real",
    desc: "Cada envío lleva un identificador único consultable desde portal o API.",
  },
  {
    title: "Equipo humano, no bots",
    desc: "Tu cuenta tiene un gestor dedicado que responde en menos de 15 minutos.",
  },
  {
    title: "Cobertura paneuropea",
    desc: "Acuerdos con 90+ partners para llegar a 27 países sin subcontratar a ciegas.",
  },
  {
    title: "Seguro de mercancía",
    desc: "Todas las cargas viajan con póliza all-risk incluida hasta 50.000 €/envío.",
  },
];
---

<section id="nosotros" class="bg-white py-24">
  <div class="container-x grid items-start gap-16 md:grid-cols-2">
    <div>
      <span class="badge-eyebrow">Por qué nosotros</span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-brand-navy md:text-4xl">
        Operadores, no intermediarios.
      </h2>
      <p class="mt-4 max-w-xl text-slate-600">
        En Prada GL gestionamos la cadena completa con personal propio, flota
       monitorizada y partenaires auditados. Cuando algo se mueve, lo controlamos
        nosotros — no nos lo cuentan.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <span class="rounded-full bg-brand-navy/5 px-3 py-1 text-xs font-semibold text-brand-navy">
          ISO 9001
        </span>
        <span class="rounded-full bg-brand-navy/5 px-3 py-1 text-xs font-semibold text-brand-navy">
          GDP Pharma
        </span>
        <span class="rounded-full bg-brand-navy/5 px-3 py-1 text-xs font-semibold text-brand-navy">
          AEO Operador Económico Autorizado
        </span>
      </div>
    </div>

    <ul class="grid gap-4">
      {
        bullets.map((bullet) => (
          <li class="flex gap-4 rounded-xl border border-slate-200 bg-slate-50 p-5 transition hover:border-brand-red/40 hover:bg-white hover:shadow-md">
            <span class="mt-1 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-brand-red text-white">
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 0 1 1.4-1.4l3.8 3.8 6.8-6.8a1 1 0 0 1 1.4 0Z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
            <div>
              <p class="font-semibold text-brand-navy">{bullet.title}</p>
              <p class="mt-1 text-sm text-slate-600">{bullet.desc}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
