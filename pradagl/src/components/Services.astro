---
const services = [
  {
    title: "Transporte terrestre",
    desc: "Carga completa (FTL) y grupaje (LTL) con rutas diarias nacionales y cross-border.",
    icon: "truck",
  },
  {
    title: "Carga aérea",
    desc: "Envíos urgentes consolidados o dedicados con prioridad en hubs internacionales.",
    icon: "plane",
  },
  {
    title: "Carga marítima",
    desc: "FCL y LCL desde los principales puertos con servicios door-to-door.",
    icon: "ship",
  },
  {
    title: "Almacenamiento",
    desc: "Operamos 14.000 m² con picking, packing, cross-docking y control de inventario.",
    icon: "warehouse",
  },
  {
    title: "Distribución urbana",
    desc: "Last-mile con flota eléctrica, ventanas de entrega y notificaciones al destinatario.",
    icon: "map",
  },
  {
    title: "Despacho aduanas",
    desc: "Equipo propio tramitando DUA, DAE y regímenes especiales sin demoras.",
    icon: "doc",
  },
];
---

<section id="servicios" class="bg-slate-50 py-24">
  <div class="container-x">
    <div class="max-w-2xl">
      <span class="badge-eyebrow">Servicios</span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-brand-navy md:text-4xl">
        Una sola operadora para toda tu cadena.
      </h2>
      <p class="mt-4 text-slate-600">
        Combinamos modos de transporte según urgencia, coste y huella. Tú marcas el
        objetivo; nosotros movemos la mercancía.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article
            class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-brand-red/40 hover:shadow-xl"
          >
            <span
              aria-hidden="true"
              class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-brand-red transition-transform duration-300 group-hover:scale-x-100"
            ></span>

            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red transition group-hover:bg-brand-red group-hover:text-white"
            >
              {service.icon === "truck" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 7h11v8H3z" />
                  <path d="M14 10h4l3 3v2h-7z" />
                  <circle cx="7" cy="17" r="1.6" />
                  <circle cx="17.5" cy="17" r="1.6" />
                </svg>
              )}
              {service.icon === "plane" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 13l9-2 4-7 2 1-2 7 7 4-1 2-7-1-3 6-2-1 1-6-7-2z" stroke-linejoin="round" />
                </svg>
              )}
              {service.icon === "ship" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 18a3 3 0 0 0 3 2h12a3 3 0 0 0 3-2" stroke-linejoin="round" />
                  <path d="M5 14V8h14v6" />
                  <path d="M12 4v4" />
                  <path d="M9 11h6" />
                </svg>
              )}
              {service.icon === "warehouse" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 11l9-5 9 5v10H3z" stroke-linejoin="round" />
                  <path d="M9 21v-6h6v6" stroke-linejoin="round" />
                </svg>
              )}
              {service.icon === "map" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 4 3 6v14l6-2 6 2 6-2V4l-6 2z" stroke-linejoin="round" />
                  <path d="M9 4v14M15 6v14" />
                </svg>
              )}
              {service.icon === "doc" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 3h9l4 4v14H6z" stroke-linejoin="round" />
                  <path d="M14 3v5h5M9 13h6M9 17h6M9 9h2" />
                </svg>
              )}
            </div>

            <h3 class="mt-6 text-lg font-bold text-brand-navy">
              {service.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{service.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
