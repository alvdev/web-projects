---
import { Image } from "astro:assets";
import logo from "../images/prada-logo.webp";

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50">
    <div
        class="container-x flex flex-col items-start justify-between gap-6 py-10 text-sm text-slate-600 md:flex-row md:items-center"
    >
        <div class="flex items-center gap-2 font-semibold text-brand-navy">
            <Image src={logo} alt="Prada GL" class="h-8 w-auto" />
        </div>
        <p class="text-xs">© {year} Prada Global Logistics S.L. · Todos los derechos reservados.</p>
        <p class="text-xs">Av. de la Logística 42 · 28021 Madrid · CIF B-00000000</p>
    </div>
</footer>
