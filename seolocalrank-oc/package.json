{
  "name": "seolocalrank",
  "private": true,
  "scripts": {
    "build:css": "bun tailwindcss -i src/input.css -o dist/output.css",
    "build:js": "bun build src/app.js --outdir=dist",
    "build": "bun run build:css && bun run build:js",
    "dev:css": "bun tailwindcss -i src/input.css -o dist/output.css --watch",
    "dev:js": "bun build src/app.js --outdir=dist --watch",
    "dev": "bun run dev:css & bun run dev:js"
  },
  "dependencies": {
    "alpinejs": "^3.14.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
