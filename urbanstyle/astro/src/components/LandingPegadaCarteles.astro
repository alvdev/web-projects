---
import { Image } from "astro:assets";
import ContactForm from "../components/ContactForm.astro";
import ActionsImg from "@/assets/images/landings/acciones-marketing-local.webp";
import CulturalImg from "@/assets/images/landings/campañas-culturales.webp";
import EventsImg from "@/assets/images/landings/promocion-de-eventos.webp";
import LaunchImg from "@/assets/images/landings/lanzamientos-de-marca.webp";

const { city } = Astro.props;
const campaigns = [
    {
        title: "Campañas culturales",
        img: ActionsImg,
        imgClasses: "z-0 rotate-1",
        titleClasses: "-rotate-10 -left-12",
    },
    {
        title: "Promoción de eventos",
        img: EventsImg,
        imgClasses: "relative -z-0 md:-top-8 -left-8 -rotate-1",
        titleClasses: "rotate-10 -right-8 md:-right-12",
    },
    {
        title: "Acciones de marketing local",
        img: CulturalImg,
        imgClasses: "md:-top-0 md:left-2 -z-0 -rotate-2",
        titleClasses: "rotate-10 -left-12 bottom-0",
    },
    {
        title: "Lanzamientos de marca",
        img: LaunchImg,
        imgClasses: "md:-top-8 -left-4 z-0 rotate-2",
        titleClasses: "-rotate-10 -right-8 md:-right-12 bottom-0",
    },
];
---

<!-- Breadcrumbs for SEO -->
<nav aria-label="Breadcrumb" class="container absolute inset-0 h-fit text-sm text-gray-500">
    <ul class="list-none mx-auto flex flex-wrap items-center justify-center gap-2" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="/" itemprop="item" class="hover:text-red-700 transition-colors">
                <span itemprop="name">Portada</span>
            </a>
            <meta itemprop="position" content="1" />
            <span class="mx-2">/</span>
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="/pegada-carteles" itemprop="item" class="hover:text-red-700 transition-colors">
                <span itemprop="name">Pegada de carteles</span>
            </a>
            <meta itemprop="position" content="2" />
            <span class="mx-2">/</span>
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="text-gray-800 font-medium">
            <span itemprop="name" aria-current="page">{city.name}</span>
            <meta itemprop="position" content="3" />
        </li>
    </ul>
</nav>

<section class="container">
    <hgroup class="text-center text-balance">
        <h2 class="text-4xl md:text-6xl font-bold">
            {city.title}
        </h2>
        <p class="font-script text-4xl font-semibold text-gray-500 mt-8">
            Trabajamos principalmente en <mark class="under text-gray-700">{city.type}</mark>.
        </p>
    </hgroup>
</section>

{city.description ? (
    <section class="container mt-12">
        <div class="max-w-4xl mx-auto text-center">
            <p class="text-2xl text-gray-600 leading-relaxed text-balance">
                {city.description}
            </p>
        </div>
    </section>
) : null}

<section class="mt-32 torn-top torn-bottom">
    <div class="wall-full bg-red-900">
        <div class="container text-white py-28">
            <h2
                class="font-bold [text-shadow:2px_2px_2px_black] text-5xl md:text-6xl uppercase xl:m-0 text-center text-white"
            >
                Tipos de campañas de cartelería en {city.name}
            </h2>

            <ul class="mt-32 grid md:grid-cols-2 list-none uppercase text-4xl">
                {
                    campaigns.map(item => (
                        <li
                            class={`relative m-0 group aspect-4/3 border-4 border-transparent bg-white rounded shadow-xl ${item.imgClasses}`}
                        >
                            <Image
                                src={item.img}
                                width={600}
                                decoding="async"
                                loading="lazy"
                                class="absolute inset-0 w-full h-full object-cover rounded"
                                alt={item.title}
                            />
                            <div
                                class={`absolute bg-black/80 px-6 md:px-8 py-4 text-xs md:text-3xl font-bold text-center shadow-xl ${item.titleClasses}`}
                            >
                                {item.title}
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
</section>



{Array.isArray(city.faq) && city.faq.length > 0 ? (
    <section class="container mt-32">
        <h2 class="text-4xl md:text-6xl font-bold text-center mb-16 text-balance">
            Preguntas frecuentes sobre la pegada de carteles en {city.name}
        </h2>
        <div
            x-data="{ activeAccordion: '', setActiveAccordion(id) { this.activeAccordion = (this.activeAccordion == id) ? '' : id } }"
            class="relative max-w-4xl mx-auto"
        >
            <div class="relative w-full">
                {city.faq.map((item, i) => (
                    <div
                        x-data="{ id: $id('accordion') }"
                        :class="{ 'text-neutral-900': activeAccordion==id, '': activeAccordion!=id }"
                        class="relative not-first:mt-4 md:not-first:mt-6 lg:not-first:mt-8 text-black text-pretty hover:*:[button]:cursor-pointer after:absolute after:content-[''] after:w-full after:h-full after:left-1.5 after:-bottom-1.5 after:-z-50 after:bg-black transition-all"
                    >
                        <button
                            @click="setActiveAccordion(id)"
                            class="relative border-2 flex items-center justify-between w-full bg-white py-4 px-6 text-left group"
                        >
                            <span>{item.q}</span>
                            <div>
                                <svg
                                    class="w-5 h-5 duration-300 ease-out stroke-white bg-red-700 rounded-full group-hover:ring-2 ring-red-700"
                                    :class="{'-rotate-[45deg]': activeAccordion==id}"
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                >
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6"></path>
                                </svg>
                            </div>
                        </button>
                        <div class="pb-1" x-show="activeAccordion==id" x-collapse x-cloak>
                            <div class="relative pl-10 pr-6 pt-6 pb-5 text-white">
                                {item.a}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
) : null}

<section class="container my-24">
    <div class="text-center">
        <h2 class="text-4xl md:text-6xl font-bold mb-6 text-balance">
            Presupuesto para hacer una pegada de carteles en {city.name}
        </h2>
        <p class="mb-8 text-balance text-3xl leading-normal font-script">
            Solicita un presupuesto personalizado para tu campaña en {city.name}
            completando el formulario o llamándonos al
            <a href="tel:+34913052922" class="inline-block relative top-0.5 ml-1 font-bolder text-3xl">91 305 29 22</a>
        </p>
    </div>

    <div class="container lg:w-2/3">
        <ContactForm />
    </div>
</section>
