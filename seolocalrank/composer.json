{
    "name": "alvdev/seolocalrank",
    "description": "A simple, fast local & international Google SERP checker inspired by valentin.app",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "SeoLocalRank\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
